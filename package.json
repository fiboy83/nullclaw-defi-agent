{
  "name": "nullclaw-defi-agent",
  "version": "0.1.0",
  "description": "Autonomous DeFi Agent powered by NullClaw (Zig) + Tether WDK -- Hackathon Galactica submission",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:sidecar\" \"npm run dev:ui\"",
    "dev:ui": "cd ui && npx vite --port ${PORT:-5173} --host 0.0.0.0",
    "dev:sidecar": "cd sidecar && node --watch server.js",
    "build": "cd ui && npm run build",
    "start": "node start.js",
    "start:sidecar": "cd sidecar && node server.js",
    "start:ui": "cd ui && npx vite preview --host 0.0.0.0 --port ${PORT:-5173}",
    "setup": "npm install && cd sidecar && npm install && cd ../ui && npm install",
    "preview": "npm run build && npm run start:ui"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
