# ============================================
# NullClaw DeFi Agent -- Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp env.example .env

# --- WDK Wallet (REQUIRED) ---
# 12 or 24 word BIP-39 seed phrase for WDK wallet
# IMPORTANT: Use a TESTNET-ONLY wallet. Never use your main wallet!
# Generate one at: https://iancoleman.io/bip39/
SEED_PHRASE=your twelve word seed phrase goes here replace with real words

# --- EVM Configuration (Sepolia Testnet) ---
EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Sepolia testnet token addresses (defaults are pre-filled)
EVM_USDT_ADDRESS=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06
EVM_WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
EVM_USDC_ADDRESS=0x94a9D9AC8a22534E3FaCa9F4e7F2E2cf85d5E4C8
EVM_DAI_ADDRESS=0xFF34B3d4Aee8ddCd6F9AFFFB6Fe49bD371b8a357

# --- Solana Configuration (Devnet) ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOL_USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB
SOL_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- LLM Agent Brain (OPTIONAL) ---
# Required for autonomous decision-making features
# Supports: Groq (free), OpenAI, Grok (xai), OpenRouter
# Groq (free): https://console.groq.com
# OpenAI: https://platform.openai.com/api-keys
# Grok: https://console.x.ai
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# Alternative configs:
# Groq:     AI_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=llama-3.3-70b-versatile
# OpenAI:   AI_BASE_URL=https://api.openai.com/v1         LLM_MODEL=gpt-4o-mini
# Grok:     AI_BASE_URL=https://api.x.ai/v1               LLM_MODEL=grok-2-latest
# OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=meta-llama/llama-3-70b

# --- Server ---
SIDECAR_PORT=3001
