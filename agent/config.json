{
  "agent": {
    "name": "NullClaw",
    "version": "0.2.0",
    "framework": "nullclaw",
    "description": "Autonomous DeFi Agent with multi-chain WDK integration and LLM-powered decision engine",
    "license": "Apache-2.0"
  },
  "chains": {
    "evm": {
      "enabled": true,
      "network": "sepolia",
      "chainId": 11155111,
      "rpcUrl": "https://ethereum-sepolia-rpc.publicnode.com",
      "explorer": "https://sepolia.etherscan.io",
      "faucet": "https://sepoliafaucet.com",
      "tokens": {
        "USDT": "0x7169D38820dfd117C3FA1f22a697dBA58d90BA06",
        "WETH": "0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14",
        "USDC": "0x94a9D9AC8a22534E3FaCa9F4e7F2E2cf85d5E4C8",
        "DAI": "0xFF34B3d4Aee8ddCd6F9AFFFB6Fe49bD371b8a357"
      }
    },
    "solana": {
      "enabled": true,
      "network": "devnet",
      "rpcUrl": "https://api.devnet.solana.com",
      "explorer": "https://explorer.solana.com/?cluster=devnet",
      "faucet": "https://faucet.solana.com",
      "tokens": {
        "USDT": "Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB",
        "USDC": "4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"
      }
    }
  },
  "protocols": {
    "swap": {
      "provider": "velora",
      "module": "@tetherto/wdk-protocol-swap-velora-evm",
      "chains": ["evm"],
      "maxSlippage": 0.5,
      "maxFeeWei": "200000000000000"
    },
    "lending": {
      "provider": "aave-v3",
      "module": "@tetherto/wdk-protocol-lending-aave-evm",
      "chains": ["evm"],
      "minHealthFactor": 1.5
    },
    "bridge": {
      "provider": "usdt0",
      "module": "@tetherto/wdk-protocol-bridge-usdt0-evm",
      "chains": ["evm"]
    }
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "temperature": 0.3,
    "maxTokens": 1500,
    "analysisIntervalMs": 60000,
    "optimizeIntervalMs": 300000
  },
  "risk": {
    "maxSingleTradePercent": 0.2,
    "maxPortfolioRiskPercent": 0.5,
    "healthFactorWarning": 1.5,
    "healthFactorCritical": 1.1,
    "minGasReserve": {
      "evm": "0.01",
      "solana": "0.05"
    },
    "requireConfirmation": true,
    "autoRejectAboveUsd": 1000
  },
  "skills": [
    {
      "id": "portfolio-monitor",
      "name": "Cross-Chain Portfolio Monitor",
      "description": "Continuously monitors balances and positions across EVM and Solana",
      "trigger": "interval",
      "interval": 30000
    },
    {
      "id": "yield-optimizer",
      "name": "Aave Yield Optimizer",
      "description": "Analyzes Aave rates and suggests optimal supply/borrow strategies",
      "trigger": "interval",
      "interval": 300000
    },
    {
      "id": "risk-guardian",
      "name": "Liquidation Risk Guardian",
      "description": "Monitors health factor and triggers emergency repay if needed",
      "trigger": "threshold",
      "threshold": "healthFactor < 1.2"
    },
    {
      "id": "swap-scout",
      "name": "Swap Opportunity Scout",
      "description": "Identifies favorable swap conditions via Velora quotes",
      "trigger": "interval",
      "interval": 120000
    },
    {
      "id": "rebalancer",
      "name": "Cross-Chain Rebalancer",
      "description": "Suggests bridging or transfers to maintain target allocation",
      "trigger": "deviation",
      "deviationPercent": 10
    }
  ],
  "api": {
    "sidecarPort": 3001,
    "endpoints": {
      "wallet": "/api/wallet",
      "defi": "/api/defi",
      "market": "/api/market",
      "agent": "/api/agent",
      "health": "/api/health"
    }
  }
}
